# MediHelper — Environment Configuration
# Copy this file to .env and fill in your MySQL credentials.
# If MySQL is unreachable the backend will automatically fall back to SQLite.

# MySQL connection (primary)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=medihelper

# JWT secret (change in production!)
JWT_SECRET=medihelper_secret_key_2026

# Server port
PORT=5000
